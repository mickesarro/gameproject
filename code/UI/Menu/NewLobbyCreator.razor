@using Sandbox;
@using Sandbox.UI;
@using UISystem
@inherits UILayer
@namespace Shooter.UI

<root>
    <div class="menu_center">
        <div class="menu_cluster">
            <h1>Create Game</h1>

            <div class="section_box presets_box">
                <h2>Presets</h2>
                <div class="btn_list">
                    @foreach ( var mode in ResourceLibrary.GetAll<PrefabFile>("gamemodes/") )
                    {
                        string label = mode.GetMetadata("Name", mode.ResourceName);
                        <UIButton class="menu_btn" T="string" DisplayValue="@label" ButtonCallback="@(() => StartGame(mode.ResourceName))"></UIButton>
                    }
                </div>
            </div>

            <div class="section_box custom_box">
                <h2>Advanced</h2>
                <div class="btn_list">
                    <UIButton class="menu_btn custom_btn" T="string" DisplayValue="Custom Game" ButtonCallback="@CustomGame"></UIButton>
                </div>
            </div>

            <div class="spacer"></div>
            <UIButton class="menu_btn back_btn" T="string" DisplayValue="← Back" ButtonCallback="@GoBack"></UIButton>
        </div>
    </div>
</root>

@code
{
    private void StartGame( string gameModePrefab, string scene = "/scenes/main.scene" )
    {
        Log.Info( $"Loading game scene: {scene} with gamemode: {gameModePrefab}" );
        var slo = new SceneLoadOptions { ShowLoadingScreen = true };
        slo.SetScene( scene );
        Scene.Load( slo );

        GameMode.SetGameMode($"gamemodes/{gameModePrefab}.prefab");
        Mouse.Visibility = MouseVisibility.Hidden;

        // Can be used to change loading screen 
        //LoadingScreen.Media = "splash.png";
        LoadingScreen.Title = "Starting Game...";
    }

    private void CustomGame()
    {
        Log.Info("Not implemented yet");
    }

    private void GoBack()
    {
        UIManager.Instance.ShowLayerWithData<MainMenu>("PlayOptions");
    }
}