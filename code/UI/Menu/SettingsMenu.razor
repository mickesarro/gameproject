@using Sandbox.UI
@using UISystem
@using System
@inherits UILayer
@namespace Shooter.UI

<root>
    <div class="menu_center">
        <div class="menu_cluster">
            <h1>Preferences</h1>

            <div class="section_box">
                <div class="dropdown_section">
                    <div class="dropdown_row">
                        <UIButton class="menu_btn dropdown_button" T="string" DisplayValue="Crosshair: @SelectedCrosshairLabel ▼" ButtonCallback="@(() => OpenSettingContextMenu("Style"))" /> 
                        <CrosshairPreview Style="@SelectedCrosshair" ColorHex="@SelectedColorHex" />
                    </div>
                    <DropDown @ref="CrosshairDropdown" class="crosshair_dropdown" style="display:none;" />
                </div>

                <div class="dropdown_section">
                    <div class="dropdown_row">
                        <UIButton class="menu_btn dropdown_button" T="string" DisplayValue="Crosshair Color: @SelectedColorLabel ▼" ButtonCallback="@(() => OpenSettingContextMenu("Color"))" /> 
                        <div class="color_preview" style="background-color: @SelectedColorHex;"></div>
                    </div>
                    <DropDown @ref="ColorDropdown" class="color_dropdown" style="display:none;" />
                </div>

                <div class="dropdown_section">
                    <div class="dropdown_row">
                        <UIButton class="menu_btn dropdown_button" T="string" DisplayValue="HUD Color: @SelectedHudColorLabel ▼" ButtonCallback="@(() => OpenSettingContextMenu("HudColor"))" /> 
                        <div class="color_preview" style="background-color: @SelectedHudColorHex;"></div>
                    </div>
                    <DropDown @ref="HudColorDropdown" class="color_dropdown" style="display:none;" />
                </div>

                <div class="slider_section">
                    <label class="slider_label">FOV: @currentFov</label>
                    <SliderControl Min="@MinFov" Max="@MaxFov" Step="@Step" Value="@currentFov" OnValueChanged="@OnFovChanged" ShowRange="@true" ShowValueTooltip="@false" />
                </div>

                <div class="dropdown_section">
                    <div class="dropdown_row">
                        <UIButton class="menu_btn dropdown_button" T="string" DisplayValue="Show Speed: @SelectedSpeedDisplayLabel ▼" ButtonCallback="@(() => OpenSettingContextMenu("SpeedDisplay"))" /> 
                    </div>
                    <DropDown @ref="SpeedDisplayDropdown" class="speed_dropdown" style="display:none;" />
                </div>
            </div>

            <div class="spacer"></div>
            <UIButton class="menu_btn back_btn" T="string" DisplayValue="← Back" ButtonCallback="@GoBack"></UIButton>
        </div>
    </div>
</root>

@code {
    public bool ShowSettingsOptions { get; set; } = false;

    private DropDown CrosshairDropdown;
    private DropDown ColorDropdown;
    private DropDown HudColorDropdown;

    private float currentFov;
    private float MinFov => playerPreferences.minFov;
    private float MaxFov => playerPreferences.maxFov;
    private float Step => 1f;

    private PlayerPreferences playerPreferences;
    
    private CrosshairType SelectedCrosshair => playerPreferences.CrosshairStyle;
    private string SelectedColorHex => playerPreferences.CrosshairColor;
    private string SelectedHudColorHex => playerPreferences.HudColor;

    private string SelectedCrosshairLabel => SelectedCrosshair.ToDisplayName();
    private string SelectedColorLabel => Crosshair.AvailableColors.FirstOrDefault(c => c.Hex == SelectedColorHex).Name ?? "Unknown";
    private string SelectedHudColorLabel => Crosshair.AvailableColors.FirstOrDefault(c => c.Hex == SelectedHudColorHex).Name ?? "Unknown";

    private DropDown SpeedDisplayDropdown;
    private SpeedDisplayPosition SelectedSpeedDisplay => playerPreferences.SpeedDisplay;
    private string SelectedSpeedDisplayLabel => GetSpeedDisplayLabel(SelectedSpeedDisplay);

    protected override int BuildHash() => System.HashCode.Combine(SelectedCrosshair, SelectedColorHex, SelectedHudColorHex, currentFov, SelectedSpeedDisplay);
    
    protected override void OnEnabled()
    {
        base.OnEnabled();
        playerPreferences = SettingsManager.Instance.PlayerPreferences;
        currentFov = playerPreferences.Fov;
    }

    protected override void OnUpdate()
    {
        base.OnUpdate();

        if ( Input.EscapePressed )
        {
            // Suppress default s&box menu
            Input.EscapePressed = false;

            GoBack();
        }
    }

    private void OnFovChanged(float fov)
    {
        currentFov = fov;
        SettingsManager.Instance.SetFOV(currentFov);
        StateHasChanged();
    }

    public override void Show()
    {
        Mouse.Visibility = MouseVisibility.Visible;
        GameObject.Enabled = true;

        if (!SettingsManager.Instance.IsLoaded)
            SettingsManager.Instance.Load();
    }

    public override void Hide()
    {
        GameObject.Enabled = false;
        SettingsManager.Instance?.Save();
    }

    public void GoBack()
    {
        UIManager.Instance.ShowLastLayer();

        // 2. Check which menu we're on
        if (UIManager.Instance.CurrentLayer is MainMenu mainMenu)
        {
            mainMenu.OpenSettingsOptions();
        }
        else if (UIManager.Instance.CurrentLayer is PauseMenu pauseMenu)
        {
            pauseMenu.OpenSettingsOptions();
        }
    }

    private string GetSpeedDisplayLabel(SpeedDisplayPosition pos)
    {
        return pos switch
        {
            SpeedDisplayPosition.Off => "Off",
            SpeedDisplayPosition.UnderCrosshair => "Under Crosshair",
            SpeedDisplayPosition.TopLeft => "Top Left",
            SpeedDisplayPosition.TopRight => "Top Right",
            SpeedDisplayPosition.BottomLeft => "Bottom Left",
            SpeedDisplayPosition.BottomRight => "Bottom Right",
            _ => "Unknown"
        };
    }

    private void OpenSettingContextMenu(string settingType)
    {
        DropDown targetDropdown = settingType == "Style" ? CrosshairDropdown : 
                                  settingType == "Color" ? ColorDropdown : HudColorDropdown;
        
        if (targetDropdown == null) return;

        var popup = new Popup(targetDropdown, Popup.PositionMode.BelowLeft, 45);
        if (settingType == "Style")
        {
            foreach (CrosshairType type in Enum.GetValues<CrosshairType>())
            {
                string label = type.ToDisplayName();
                var panel = popup.AddOption(label, "", () =>
                {
                    SettingsManager.Instance.SetCrosshairStyle(type);
                    StateHasChanged();
                });
                if (type == SelectedCrosshair) panel.AddClass("active");
                
                panel.Style.Width = 280;
                panel.Style.BackgroundColor = Color.Black.WithAlpha(0.4f);
                panel.Style.FontColor = Color.White;
            }
        }
        else if  ( settingType == "SpeedDisplay" )
        {
            foreach (SpeedDisplayPosition type in Enum.GetValues<SpeedDisplayPosition>())
            {
                var panel = popup.AddOption(GetSpeedDisplayLabel(type), "", () =>
                {
                    SettingsManager.Instance.SetSpeedDisplay(type);
                    StateHasChanged();
                });
                if (type == SelectedSpeedDisplay) panel.AddClass("active");
                
                panel.Style.Width = 280;
                panel.Style.BackgroundColor = Color.Black.WithAlpha(0.4f);
                panel.Style.FontColor = Color.White;
            }
        }
        else if (settingType == "Color" || settingType == "HudColor")
        {
            foreach (var color in Crosshair.AvailableColors)
            {
                var panel = popup.AddOption(color.Name, "", () =>
                {
                    if (settingType == "Color")
                        SettingsManager.Instance.SetCrosshairColor(color.Hex);
                    else
                        SettingsManager.Instance.SetHudColor(color.Hex);
                    
                    StateHasChanged();
                });
                
                if (color.Hex == SelectedColorHex) panel.AddClass("active");
                
                panel.Style.BackgroundColor = Color.Black.WithAlpha(0.4f);
                panel.Style.Width = 280;
                panel.Style.FontFamily = "Poppins";
                panel.Style.FontColor = Color.Parse(color.Hex);
            }
        }

        popup.CloseWhenParentIsHidden = true;
    }
}
