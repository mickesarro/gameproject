@using Sandbox;
@using Sandbox.UI;
@using System.Linq;
@using Shooter;
@inherits PanelComponent

<root>
    @if (ActiveStage != null && ActiveStage.IsStageActive && ActiveStage.Instructions.Count > 0)
    {
        var instruction = ActiveStage.CurrentInstruction;
        
        <div class="instruction-panel" @key="ActiveStage.CurrentInstructionIndex">
            
            <h1 class="stage-title">@ActiveStage.StageName</h1>
            
            @if (!string.IsNullOrWhiteSpace(instruction.MediaPath))
            {
                <div class="media-container">
                    <div class="tutorial-media" style="background-image: url('@instruction.MediaPath');"></div>
                </div>
            }

            <p class="instruction-text">@instruction.Text</p>
            
            <div class="controls">
                <div class="control-text @(ActiveStage.CurrentInstructionIndex > 0 ? "" : "hidden")">
                    ◀ [BACK] Previous
                </div>
                <div class="control-text @(CanGoNext() ? "" : "hidden")">
                    [USE] Next ▶
                </div>
            </div>
            
        </div>
    }
</root>

@code {
    public TutorialGameMode GameMode => Game.ActiveScene.GetAllComponents<TutorialGameMode>().FirstOrDefault();
    public TutorialStage ActiveStage => GameMode?.CurrentStage;

    /// <summary>
    /// BuildHash tells the UI when it needs to update. We tie it to the instruction index and objective status.
    /// </summary>
    protected override int BuildHash()
    {
        return System.HashCode.Combine(ActiveStage?.CurrentInstructionIndex, ActiveStage?.ObjectiveCompleted, ActiveStage?.IsStageActive);
    }

    /// <summary>
    /// Helper to determine if we should show the "Next" button hint
    /// </summary>
    private bool CanGoNext()
    {
        if (ActiveStage == null) return false;
        if (ActiveStage.ObjectiveCompleted) return true; 
        return ActiveStage.CurrentInstructionIndex < ActiveStage.Instructions.Count - 2;
    }
}