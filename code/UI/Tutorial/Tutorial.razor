@using Sandbox
@using Sandbox.UI
@using System.Text.RegularExpressions
@using Shooter.UISystem
@inherits UILayer

@namespace Shooter.UI

<root>

    <KeyOverlay />
    @if (TutorialGameMode.InputOverlay) return; @* Don't want to show the rest of the UI when filming tutorials *@

    @if (ActiveStage != null && ActiveStage.IsStageActive && ActiveStage.Instructions.Count > 0)
    {
        var instruction = ActiveStage.CurrentInstruction;
        var hasMedia = !string.IsNullOrWhiteSpace(instruction.MediaPath);
        bool hasCheckpoint = Checkpoints > 0;

        <SpawnTransition />
        
        <div class="instruction-panel @(hasMedia ? "has-media" : "")" @key="ActiveStage.CurrentInstructionIndex">
            
            <h1 class="stage-title">@ActiveStage.StageName</h1>

            <div class="instruction-text">Objective: </div>

            @if (!string.IsNullOrWhiteSpace(ActiveStage.ObjectiveText))
            {
                <div class="objective-container @(ActiveStage.ObjectiveCompleted ? "completed" : "")">
                    <div class="icon">@(ActiveStage.ObjectiveCompleted ? "✔" : "❌")</div>
                    <div class="text">@ActiveStage.ObjectiveText</div>
                </div>
            }
            
            @if (hasMedia)
            {
                <div class="media-container">
                    <div class="tutorial-media" style="background-image: url('@instruction.MediaPath');"></div>
                </div>
            }

            <div class="instruction-text">
            @foreach (var line in GetParsedLines(instruction.Text))
            {
                <div class="instruction-line">@line</div>
            }
        </div>
            
            <div class="controls">
                <div class="control-text @(ActiveStage.CurrentInstructionIndex > 0 ? "" : "hidden")">
                    ◀ <div class="key-box">@(Input.GetButtonOrigin("back")?.ToUpper() ?? "Q")</div> PREVIOUS
                </div>
                
                @if (hasCheckpoint)
                {
                    <div class="control-text center-action">
                        <div class="key-box">
                            <div class="fill" style="width: @(Shooter.TutorialStage.ReloadHoldProgress * 100)%"></div>
                            <div class="key-text">@(Input.GetButtonOrigin("reload")?.ToUpper() ?? "R")</div>
                        </div>
                        <div class="action-labels">
                            <span>CHECKPOINT (PRESS)</span>
                            <span>START (HOLD)</span>
                        </div>
                    </div>
                }
                
                <div class="control-text @(CanGoNext() ? "" : "hidden")">
                    NEXT <div class="key-box">@(Input.GetButtonOrigin("use")?.ToUpper() ?? "E")</div> ▶
                </div>
            </div>
            
        </div>
    }

</root>

@code {
    public TutorialGameMode GameMode => Game.ActiveScene.GetAllComponents<TutorialGameMode>().FirstOrDefault();
    public TutorialStage ActiveStage => GameMode?.CurrentStage;
    public int Checkpoints => ActiveStage.Checkpoints.Count();

    protected override int BuildHash()
    {
        return System.HashCode.Combine(
            GameMode?.CurrentStageIndex,
            ActiveStage?.CurrentInstructionIndex, 
            ActiveStage?.ObjectiveCompleted, 
            ActiveStage?.IsStageActive,
            Shooter.TutorialStage.ReloadHoldProgress
        );
    }

    private bool CanGoNext()
    {
        if (ActiveStage == null) return false;
        if (ActiveStage.Instructions.Count <= 1) return false;
        if (ActiveStage.ObjectiveCompleted) return true; 
        return ActiveStage.CurrentInstructionIndex < ActiveStage.Instructions.Count - 2;
    }

    // --- Instruction parser so that newlines get parsed correctly ---
    private string PreserveEdgeSpaces(string text)
    {
        if (string.IsNullOrEmpty(text)) return text;
        
        text = Regex.Replace(text, @"^ +", m => new string('\u00A0', m.Length));
        
        text = Regex.Replace(text, @" +$", m => new string('\u00A0', m.Length));
        
        return text;
    }

    public struct TextSegment
    {
        public string Text { get; set; }
        public string CssClass { get; set; }
    }

    private IEnumerable<string> GetParsedLines(string input)
    {
        if (string.IsNullOrEmpty(input)) yield break;

        var lines = input.Replace("\r", "").Split('\n');

        foreach (var line in lines)
        {
            yield return string.IsNullOrEmpty(line) ? " " : line;
        }
    }
}
