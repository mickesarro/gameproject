@using Sandbox;
@using Sandbox.UI;
@inherits UISystem.UILayer
@implements IPlayerEvent
@implements IMatchEvents
@namespace Shooter.UI

@if (!ShouldDisplay) return;

<root>
    <KillFeed @ref="killFeed" />

    @if ( countdownable != null && countdownable.IsActive )
    {
        <HUDTimer HudColour="@HudColour" Countdownable="@countdownable" />
    }

	@if (waitPlayers)
	{
		<TextPanel T="string" DisplayValue="Waiting for players..." />
	}

    @if ( PlayerAlive ) {
		<HealthBar PlayerHealth="@CharacterHealth" HudColour="@HudColour" @ref="HealthBar" />

		<AmmoCounter PlayerInventory="@PlayerInventory" HudColour="@HudColour" @ref="AmmoCounter" />
    
        <WeaponBar PlayerInventory="@PlayerInventory" HudColour="@HudColour" @ref="weaponBar" />
    }
    else
    {
        <DeathScreen DamageInfo="@lastDamageInfo" />
    }
    
</root>

@code
{
	public string HudColour = "#FFFFFF";

	private PlayerInventory PlayerInventory = null;

	WeaponBar weaponBar { get; set; }
	AmmoCounter AmmoCounter { get; set; }
	HealthBar HealthBar { get; set; }
	private KillFeed killFeed;
	private DamageInfo lastDamageInfo;

	private ICountdownable countdownable = null;

	private CharacterHealth CharacterHealth = null;

	private bool ShouldDisplay = false; // Whole HUD
	private bool PlayerAlive = true; // Player dead

	private bool waitPlayers = false;

	void IPlayerEvent.OnSpawn( GameObject player )
	{
		SetPlayerProperties( player );
	}

	void IPlayerEvent.OnDied(DamageInfo damageInfo)
	{
		lastDamageInfo = damageInfo;
		PlayerAlive = false;
	}

	void IPlayerEvent.OnAmmoAdded(IWeapon item, int amount)
	{
		AmmoCounter.OnAmmoAdded(item, amount);
		weaponBar.OnAmmoAdded(item, amount);
	}

	void IPlayerEvent.OnHealthAdded(int health)
	{
		HealthBar.OnHealthAdded(health);
	}

	//void IPlayerEvent.OnItemAdded(ICollectable item) => weaponBar.StateHasChanged();
	//void IPlayerEvent.OnWeaponAdded(IWeapon weapon) => weaponBar.StateHasChanged();

	/// <summary>
	/// the hash determines if the system should be rebuilt. If it changes, it will be rebuilt
	/// </summary>
	protected override int BuildHash() => System.HashCode.Combine( ShouldDisplay, PlayerAlive );

	void IMatchEvents.BroadcastOnKill(PlayerStats killed, DamageInfo damageInfo)
		=> killFeed.BroadcastOnKill(killed, damageInfo);

	void IMatchEvents.OnGameEnd()
	{
		ShouldDisplay = false;
	}

	void IMatchEvents.OnCountdownStart(ICountdownable countdownable)
	{
		this.countdownable = countdownable;
		StateHasChanged();
	}

	void IMatchEvents.OnWaitPlayers()
	{
		waitPlayers = true;
	}

	void IMatchEvents.OnGameStart()
	{
		waitPlayers = false;
	}

    public override void Show()
    {
        base.Show();

        if (SettingsManager.Instance != null)
        {
            UpdateHudColour(SettingsManager.Instance.PlayerPreferences?.HudColor);
            SettingsManager.Instance.OnHudColorChanged += UpdateHudColour;
        }
        // If player dies while having e.g. settings open, this is needed
        SetPlayerProperties(Shooter.PlayerController.Local?.GameObject);

    }

    public override void Hide()
    {
        base.Hide();

        SettingsManager.Instance?.OnHudColorChanged -= UpdateHudColour;
    }


    private void UpdateHudColour(string colour)
        => HudColour = colour ?? "#FFFFFF";


    private void SetPlayerProperties( GameObject player )
    {
        if ( player == null || player.IsProxy ) return;
        ShouldDisplay = true;
        PlayerAlive = true;

        CharacterHealth = player.GetComponent<CharacterHealth>();
        PlayerInventory = player.GetComponent<PlayerInventory>();

        StateHasChanged();
    }

}

