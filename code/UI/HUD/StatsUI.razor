@using Sandbox
@using Sandbox.UI
@using UISystem
@inherits UILayer
@implements IMatchEvents
@implements IPlayerEvent
@namespace Shooter.UI

<root>
    <div class="stats_menu">
        <h1>Match Stats</h1>

        <div class="stats_table">
            <div class="stats_header">
                <span class="col player">Player</span>
                <span class="col score">Score</span>
                <span class="col kills">Kills</span>
                <span class="col deaths">Deaths</span>
            </div>

            @{
                botCounter = 1;
                BuildCharacterList();
            }

            @foreach (var character in characters)
            {
                if (character.GameObject == null) continue;

				string displayName = GetDisplayName(character);

                <div class="stats_row" onclick=@(() => SelectPlayer(character))>
                    <span class="col player">
                        @if ( character.GameObject.Tags.Has( "npc" ) )
                        {
                            <div class="avatar bot-avatar"></div>
                        }
                        else if ( character.Network?.Owner != null )
                        {
                            <img class="avatar" src="avatar:@character.Network.Owner.SteamId" />
                        }
                        <span class="name">@displayName</span>
                    </span>
                    <span class="col score">@character.Score</span>
                    <span class="col kills">@character.Kills</span>
                    <span class="col deaths">@character.Deaths</span>
                </div>
            }

        </div>
        
        @if (selectedPlayer != null)
        {
            <div class="player_profile_popup">
                <div class="popup_bg" onclick=@ClosePopup></div>
                
                <div class="popup_content">
                    <div class="popup_header">
						<h2>@GetDisplayName(selectedPlayer)</h2>
                        <button class="close_btn" onclick=@ClosePopup>✕</button>
                    </div>
                    <div class="popup_body">
                        @if (selectedPlayer.GameObject.Tags.Has("npc"))
                        {
                            <div class="large_avatar bot-avatar"></div>
                            <p>This is a bot.</p>
                        }
                        else if (selectedPlayer.Network?.Owner != null)
                        {
                            <img class="large_avatar" src="avatar:@selectedPlayer.Network.Owner.SteamId" />
                            <button class="steam_btn" onclick=@(() => OpenProfile(selectedPlayer.Network.Owner.SteamId))>Profile</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</root>

@code
{
	public override bool IsOverlay => true;
	IEnumerable<PlayerStats> characters;

	bool cursorActive = false;
	PlayerStats selectedPlayer;
	int botCounter = 1;

	public override bool CanShow(UILayer currentLayer)
	{
		return currentLayer is not PauseMenu && currentLayer is not SettingsMenu;
	}

	int totalScore = 0;

	void IMatchEvents.OnScoreAdded(int score, string reason) => StateHasChanged();
	void IMatchEvents.OnPlayerJoined() => StateHasChanged();
	void IMatchEvents.OnPlayerLeft(System.Guid connectionId) => StateHasChanged();

	void IPlayerEvent.OnDied(DamageInfo _) => Hide();
	protected override int BuildHash() => System.HashCode.Combine( characters, selectedPlayer );

	private void BuildCharacterList()
	{
		characters = MatchStatsManager.Instance.Tracked
			.OrderByDescending(chr => chr?.Score);
	}

	public override void Show()
	{
		GameObject.Enabled = true;
		ResetProperties();

		StateHasChanged();
	}

	public override void Hide()
	{
		GameObject.Enabled = false;
		ResetProperties();
	}

	private void ResetProperties()
	{
		cursorActive = false;
		selectedPlayer = null;
		Mouse.Visibility = MouseVisibility.Hidden;

		if (Panel != null)
		{
			Panel.Style.PointerEvents = PointerEvents.None;
		}
	}

	protected override void OnUpdate()
	{
		if ( Panel == null ) return;

		if ( Input.Pressed( "attack2" ) )
		{
			cursorActive = !cursorActive;
			Mouse.Visibility = cursorActive ? MouseVisibility.Visible : MouseVisibility.Hidden;
			Panel.Style.PointerEvents = cursorActive ? PointerEvents.All : PointerEvents.None;
		}
	}

	private void SelectPlayer(PlayerStats player)
	{
		// Require the cursor to be enabled to select a player
		if (!cursorActive) return; 

		selectedPlayer = player;
	}

	private void ClosePopup()
	{
		selectedPlayer = null;
	}

	/// <summary>
	/// Returns the appropriate display name.
	/// Incerements botCounter if character is not a player.
	/// </summary>
	/// <param name="character"></param>
	/// <returns></returns>
	private string GetDisplayName( PlayerStats character )
	{
		// This now handles the incerement of botCounter until we
		// introduce character owning objects, i.e. object
		// under which character and all else related to it are
		if (character.GameObject.Tags.Has("npc"))
		{
			// When viewing the bot displays "wrong" number there
			return $"Bot {botCounter++} ";
		}
		return character.Network?.Owner?.DisplayName ?? "Unknown";
    }

    private async void OpenProfile(SteamId steamId)
    {
        try
        {
            Game.Overlay.ShowPlayer(steamId, "");
        }
        catch (System.Exception e)
        {
            Log.Warning($"Failed to open profile: {e.Message}");
        }
    }
}
