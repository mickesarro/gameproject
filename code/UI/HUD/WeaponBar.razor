@using Sandbox;
@using Sandbox.UI;
@inherits Panel
@namespace Shooter.UI

<root>
    <div class="weapon-hud">
        @if (PlayerInventory != null)
        {
            @for (int i = 0; i < 4; i++)
            {
                var item = PlayerInventory.Items.ElementAtOrDefault(i);
                var weapon = item as IWeapon;
                
                bool isActive = (item != null && item == PlayerInventory.CurrentItem);
                int slotLabel = i + 1;

                <div class="weapon-slot @(isActive ? "active" : "")" 
                     style="border-color: @(isActive ? HudColour : "rgba(255, 255, 255, 0.1)");">
                    
                    <div class="slot-number">@slotLabel.</div>

                    <div class="icon-container">
                        @if (weapon?.Icon != null)
                        {
                            <img src="@weapon.Icon.ResourcePath" class="weapon-icon" />
                        }
                        else if (item != null)
                        {
                            <span>@item.Name</span>
                        }
                    </div>

                    @if (weapon != null)
                    {
                        var isCharging = weapon.ChargeFraction > 0f;
                        var isOnCooldown = weapon.CooldownFraction < 1.0f;

                        if (isCharging || isOnCooldown)
                        {
                            var displayFraction = isCharging ? weapon.ChargeFraction : weapon.CooldownFraction;
                            
                            var barColor = isCharging ? "#00FFFF" : HudColour;

                            <div class="cooldown-overlay">
                                <div class="bar" style="width: @(displayFraction * 100)%; background-color: @barColor;"></div>
                            </div>
                        }
                    }
                </div>
            }
        }
    </div>
</root>

@code
{
    [Property] public PlayerInventory PlayerInventory;

    [Property] public string HudColour { get; set; } = "#FFFFFF";

    protected override int BuildHash()
    {
        var hash = new System.HashCode();
        hash.Add( PlayerInventory?.CurrentItem );

        if ( PlayerInventory?.CurrentItem is IWeapon weapon )
        {
            hash.Add( weapon.CooldownFraction );
            hash.Add( weapon.ChargeFraction );
        }

        return hash.ToHashCode();
    }
}
