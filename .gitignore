
# This file describes files and paths that should not be tracked by Git version control
# https://git-scm.com/docs/gitignore

# Auto-generated code editor files
.vs/*
.vscode/*
*.csproj
*csproj.user
obj/*
Properties/*
code/obj/*
*/obj/*
*/Properties/*
code/Properties/*
.idea/*

# Editor Projects
code/Editor/obj/*
code/Editor/Properties/*
code/Editor/*.sln
code/Editor/.vs/*
code/Editor/.vscode/*

# Auto-generated asset related files
*.generated.*
*.*_c
*.los
*.vpk
*.tmp

# Linux-fix
Libraries/tux.linuxfix/

# Visual studio and S&box config files
*.sln
*.sln.DotSettings.user
*.slnx
*.slnx.DotSettings.user
/.sbox

Exports/

testscene*
