            "IsContainerArray": true,
            "Data": {
              "__type": "Shooter.UI.TutorialPage",
              "__guid": "39d79765-413e-42dd-8e62-6460945377db",
              "__enabled": true,
              "Flags": 0,
              "Levels": [
                {
                  "Name": "Tutorial",
                  "Description": "• This tutorial goes through the movement mechanics of the game\n• If you're already familiar with source movement, It will only take a few minutes!\n\n\n",
                  "MediaPath": "media\\images\\tutorial.png",
                  "TargetStageIndex": 0
                },
                {
                  "Name": "Level 1: Bhopping",
                  "Description": "• Learn the basics of strafing and Bunnyhopping\n• You can gain speed by Bhopping, but it's mainy for maintaining your speed",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 1\\bhop1.webm",
                  "TargetStageIndex": 1
                },
                {
                  "Name": "Level 2: Rocket Jumping",
                  "Description": "• Gain speed and height by rocket jumping\n• You can switch weapons between jumps to shoot the enemy",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 2\\rocketjump1.webm",
                  "TargetStageIndex": 2
                },
                {
                  "Name": "Level 3: Jump Pads",
                  "Description": "• Jump pads are another way to get height\n• Slanted Jump Pads also speed you up\n",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 3\\jump-pad.webm",
                  "TargetStageIndex": 3
                },
                {
                  "Name": "Level 4: Jump pads 2",
                  "Description": "• You can combine jump pads and rocket jumping to gain extra velocity",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 4\\jump-pad2.webm",
                  "TargetStageIndex": 4
                },
                {
                  "Name": "Level 5: Surfing",
                  "Description": "• By surfing you can link your movements together while keeping your speed\n• And look cool doing it",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 5\\surf4.webm",
                  "TargetStageIndex": 5
                }
              ],
              "OnComponentDestroy": null,
              "OnComponentDisabled": null,
              "OnComponentEnabled": null,
              "OnComponentFixedUpdate": null,
              "OnComponentStart": null,
              "OnComponentUpdate": null
            }
          }
