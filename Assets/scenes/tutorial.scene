      "Children": [
        {
          "__guid": "8a377c33-e0b9-46df-8a44-3f3de8ae722d",
          "__version": 2,
          "Flags": 0,
          "Name": "Level 0",
          "Position": "0,0,0",
          "Rotation": "0,0,0,1",
          "Scale": "1,1,1",
          "Tags": "",
          "Enabled": true,
          "NetworkMode": 2,
          "NetworkFlags": 0,
          "NetworkOrphaned": 0,
          "NetworkTransmit": true,
          "OwnerTransfer": 1,
          "Components": [
            {
              "__type": "Shooter.TutorialStage",
              "__guid": "845b9ad0-8342-4293-a8db-d0d26f065ef2",
              "__enabled": true,
              "Flags": 0,
              "Checkpoints": [],
              "Instructions": [
                {
                  "Text": "• Welcome to the tutorial!\n• You can navigate these instructions with Previous and Next\n Page [1/2]",
                  "MediaPath": null
                },
                {
                  "Text": "• This tutorial goes through the mechanics of the game\n• If you're already familiar with source movement, It will only take a few minutes!\n Page [2/2]\n",
                  "MediaPath": null
                },
                {
                  "Text": "\n",
                  "MediaPath": null
                },
                {
                  "Text": "• Press Next to start Level 1",
                  "MediaPath": null
                }
              ],
              "ObjectiveText": "Read the instructions",
              "ObjectiveType": "ReadInstructions",
              "OnComponentDestroy": null,
              "OnComponentDisabled": null,
              "OnComponentEnabled": null,
              "OnComponentFixedUpdate": null,
              "OnComponentStart": null,
              "OnComponentUpdate": null,
              "SpawnPoint": {
                "_type": "component",
                "component_id": "d83c5c22-a447-4703-ac62-a09c39372682",
                "go": "b0cdb49e-6b15-4ecd-99fc-e8dcea8e3e14",
                "component_type": "SpawnPoint"
              },
              "StageName": "Tutorial",
              "TargetArea": null,
              "TargetSpeed": 0
            }
          ],
          "Children": []
        },
        {
          "__guid": "c849f813-0aa9-4d38-85ba-ecd89a5fdce9",
          "__version": 2,
          "Flags": 0,
          "Name": "Level 1",
          "Position": "0,0,0",
          "Rotation": "0,0,0,1",
          "Scale": "1,1,1",
          "Tags": "",
          "Enabled": true,
          "NetworkMode": 2,
          "NetworkFlags": 0,
          "NetworkOrphaned": 0,
          "NetworkTransmit": true,
          "OwnerTransfer": 1,
          "Components": [
            {
              "__type": "Shooter.TutorialStage",
              "__guid": "03fba41a-21b0-4fde-b05f-9a7886b743b7",
              "__enabled": true,
              "Flags": 0,
              "Checkpoints": [],
              "Instructions": [
                {
                  "Text": "• One of our core movement mechanics is Bhopping\n• It allows you to gain speed by jumping repeatedly\n• You can hold SPACE to auto Bhop\n Page [1/3]\n",
                  "MediaPath": null
                },
                {
                  "Text": "• Bhopping works by strafing\n• To strafe you need to slide your mouse in the same direction as your movement key\n• After you're in the air with some speed, only press left or right (No W key)\n  Page [2/3]",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 1\\bhop1.webm"
                },
                {
                  "Text": "• By strafing you gain speed\n• You can also gain speed by strafing smoothly in the same direction\n• The better you sync these movements, the more speed you gain\n Page [3/3]",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 1\\bhop2.webm"
                },
                {
                  "Text": "You got it! You can now advance to the next level",
                  "MediaPath": null
                }
              ],
              "ObjectiveText": "Reach 500 speed (u/s)",
              "ObjectiveType": "ReachSpeed",
              "OnComponentDestroy": null,
              "OnComponentDisabled": null,
              "OnComponentEnabled": null,
              "OnComponentFixedUpdate": null,
              "OnComponentStart": null,
              "OnComponentUpdate": null,
              "SpawnPoint": {
                "_type": "component",
                "component_id": "d83c5c22-a447-4703-ac62-a09c39372682",
                "go": "b0cdb49e-6b15-4ecd-99fc-e8dcea8e3e14",
                "component_type": "SpawnPoint"
              },
              "StageName": "Level 1: BHopping",
              "TargetArea": null,
              "TargetSpeed": 500
            }
          ],
          "Children": [
            {
              "__guid": "b0cdb49e-6b15-4ecd-99fc-e8dcea8e3e14",
