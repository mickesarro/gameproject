                  "component_type": "CheckpointTrigger"
                }
              ],
              "Instructions": [
                {
                  "Text": "• One of the main ways to gain speed and height is to rocket jump\n• Start by equipping the RPG\n• Shoot under your feet while jumping\n Page [1/2]",
                  "MediaPath": null
                },
                {
                  "Text": "• Control yourself in the air by strafing\n• Control the speed and angle of the jump by where you shoot\n• Reach the target without hitting the ground\n Page [2/2]",
                  "MediaPath": "Media\\Videos\\Tutorial\\Level 2\\rocketjump1.webm"
                },
                {
                  "Text": "Level 3 completed!",
                  "MediaPath": null
                }
              ],
              "ObjectiveText": "Reach the Target",
              "ObjectiveType": "ReachTargetArea",
              "OnComponentDestroy": null,
